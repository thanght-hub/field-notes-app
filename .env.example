# Sao chép file này thành .env (ở thư mục gốc, dùng chung cho docker-compose) và/hoặc
# apps/api/.env, apps/web/.env.local rồi điền giá trị thật. KHÔNG commit file .env thật lên git.

# ==== Chung ====
NODE_ENV=development
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8080

# ==== Database (apps/api) ====
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/field_notes?schema=public

# ==== Google OAuth (mục 13.1 — tạo tại Google Cloud Console > APIs & Services > Credentials) ====
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/auth/google/callback

# ==== Bảo mật (apps/api) ====
# Tạo bằng: openssl rand -base64 48
SESSION_JWT_SECRET=
# Tạo bằng: openssl rand -base64 32 — dùng để mã hoá refresh token Google trước khi lưu DB (mục 20)
TOKEN_ENCRYPTION_KEY=

# ==== Nhà cung cấp AI ====
# "mock": dùng khi phát triển/kiểm thử không có tài khoản Google Cloud thật.
# "google": dùng Speech-to-Text + Vertex AI Gemini thật.
AI_PROVIDER=mock

GOOGLE_CLOUD_PROJECT_ID=
# Đường dẫn file service-account JSON (chỉ cần nếu không chạy trên môi trường có Application Default Credentials sẵn, vd Cloud Run)
GOOGLE_APPLICATION_CREDENTIALS=
# Tên model — KHÔNG hard-code trong code, luôn kiểm tra model hiện hành trước khi triển khai (mục 27)
GOOGLE_SPEECH_MODEL=chirp_2
GOOGLE_SPEECH_LOCATION=asia-southeast1
GOOGLE_GEMINI_MODEL=gemini-2.5-flash
GOOGLE_GEMINI_LOCATION=asia-southeast1

# ==== Lưu trữ tạm (mục 14.3, 20) ====
# "local": lưu đĩa cục bộ (dev). "gcs": Google Cloud Storage (production).
STORAGE_PROVIDER=local
LOCAL_STORAGE_DIR=.data/storage
GCS_TEMP_BUCKET=
TEMP_STORAGE_TTL_DAYS=7

# ==== Giới hạn ứng dụng ====
MAX_ATTACHMENT_MB=20
MAX_MEETING_HOURS=4
REALTIME_SUMMARY_INTERVAL_SEC=180
CHUNK_TARGET_SECONDS=20
CHUNK_OVERLAP_SECONDS=2

LOG_LEVEL=info
PORT=8080

# ==== Frontend (apps/web) ====
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
